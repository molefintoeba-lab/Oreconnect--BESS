<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>OreConnect Projects | Mobile Energy Storage & Heavy Haulage | Postmasburg</title>
<meta name="description" content="OreConnect Projects – SMME supplier of container-mounted BESS Mobile Energy Storage and heavy flatbed logistics for mining, municipal, Transnet and SANDF clients. Based in Postmasburg, Northern Cape.">
<style>
  /* ── TOKENS ─────────────────────────────────────────────────────────── */
  :root {
    --navy:   #0D1F3C;
    --steel:  #1A3A5C;
    --ore:    #C8760A;   /* iron-ore amber */
    --spark:  #E8A020;   /* energy yellow */
    --slate:  #3E5368;
    --fog:    #EBF0F5;
    --white:  #FFFFFF;
    --ink:    #1C2B3A;
    --muted:  #647D94;

    --ff-display: 'Barlow Condensed', 'Arial Narrow', Arial, sans-serif;
    --ff-body:    'Inter', 'Segoe UI', Arial, sans-serif;
    --ff-mono:    'JetBrains Mono', 'Courier New', monospace;

    --radius: 4px;
    --shadow: 0 8px 32px rgba(13,31,60,0.18);
    --transition: 0.28s cubic-bezier(.4,0,.2,1);
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html { scroll-behavior: smooth; }

  body {
    font-family: var(--ff-body);
    background: var(--white);
    color: var(--ink);
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
  }

  /* ── TYPOGRAPHY ─────────────────────────────────────────────────────── */
  h1,h2,h3,h4 {
    font-family: var(--ff-display);
    letter-spacing: 0.02em;
    line-height: 1.1;
  }

  /* ── NAV ─────────────────────────────────────────────────────────────── */
  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    background: rgba(13,31,60,0.96);
    backdrop-filter: blur(12px);
    border-bottom: 2px solid var(--ore);
    display: flex; align-items: center; justify-content: space-between;
    padding: 0 5vw;
    height: 64px;
  }

  .nav-brand {
    display: flex; align-items: center; gap: 12px; text-decoration: none;
  }
  .nav-logo-mark {
    width: 42px; height: 42px;
    background: var(--ore);
    clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }
  .nav-logo-mark span {
    font-family: var(--ff-display);
    font-weight: 800; font-size: 18px;
    color: var(--navy); letter-spacing: -1px;
  }
  .nav-wordmark {
    font-family: var(--ff-display);
    font-size: 22px; font-weight: 700;
    color: var(--white); letter-spacing: 0.05em;
  }
  .nav-wordmark em {
    color: var(--spark); font-style: normal;
  }

  .nav-links {
    display: flex; gap: 32px; list-style: none;
  }
  .nav-links a {
    font-family: var(--ff-display);
    font-size: 15px; font-weight: 600; letter-spacing: 0.06em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.78);
    text-decoration: none;
    transition: color var(--transition);
    padding-bottom: 2px;
    border-bottom: 2px solid transparent;
  }
  .nav-links a:hover {
    color: var(--spark);
    border-bottom-color: var(--ore);
  }

  .nav-cta {
    background: var(--ore);
    color: var(--white) !important;
    padding: 8px 20px !important;
    border-radius: var(--radius);
    border-bottom: none !important;
  }
  .nav-cta:hover { background: var(--spark) !important; color: var(--navy) !important; }

  /* ── HERO ────────────────────────────────────────────────────────────── */
  .hero {
    min-height: 100vh;
    background: var(--navy);
    position: relative;
    overflow: hidden;
    display: flex; align-items: center;
    padding: 80px 5vw 60px;
  }

  /* Ore-seam texture overlay */
  .hero::before {
    content: '';
    position: absolute; inset: 0;
    background:
      repeating-linear-gradient(
        110deg,
        transparent 0px, transparent 28px,
        rgba(200,118,10,0.06) 28px, rgba(200,118,10,0.06) 30px
      ),
      linear-gradient(180deg, rgba(26,58,92,0.5) 0%, rgba(13,31,60,0.9) 100%);
    pointer-events: none;
  }

  /* Animated energy pulse ring */
  .hero-pulse {
    position: absolute;
    right: -120px; top: 50%;
    transform: translateY(-50%);
    width: 700px; height: 700px;
    border-radius: 50%;
    border: 1px solid rgba(200,118,10,0.18);
    animation: pulse-ring 4s ease-in-out infinite;
  }
  .hero-pulse::before {
    content: '';
    position: absolute; inset: 60px;
    border-radius: 50%;
    border: 1px solid rgba(200,118,10,0.12);
    animation: pulse-ring 4s ease-in-out 0.8s infinite;
  }
  .hero-pulse::after {
    content: '';
    position: absolute; inset: 130px;
    border-radius: 50%;
    border: 1px solid rgba(200,118,10,0.08);
    animation: pulse-ring 4s ease-in-out 1.6s infinite;
  }

  @keyframes pulse-ring {
    0%, 100% { transform: scale(1); opacity: 0.6; }
    50%       { transform: scale(1.04); opacity: 1; }
  }

  .hero-content {
    position: relative; z-index: 2;
    max-width: 680px;
  }

  .hero-eyebrow {
    font-family: var(--ff-mono);
    font-size: 12px; letter-spacing: 0.2em;
    color: var(--ore); text-transform: uppercase;
    margin-bottom: 20px;
    display: flex; align-items: center; gap: 12px;
  }
  .hero-eyebrow::before {
    content: '';
    display: block; width: 36px; height: 2px;
    background: var(--ore);
  }

  .hero h1 {
    font-size: clamp(44px, 7vw, 90px);
    font-weight: 800;
    color: var(--white);
    text-transform: uppercase;
    line-height: 0.95;
    margin-bottom: 6px;
  }
  .hero h1 .accent {
    color: var(--spark);
    display: block;
  }

  .hero-sub {
    font-size: 18px;
    color: rgba(255,255,255,0.72);
    max-width: 520px;
    margin: 24px 0 36px;
    line-height: 1.65;
  }
  .hero-sub strong { color: var(--spark); font-weight: 600; }

  .hero-actions {
    display: flex; gap: 16px; flex-wrap: wrap;
  }

  .btn-primary {
    display: inline-flex; align-items: center; gap: 8px;
    background: var(--ore);
    color: var(--white);
    font-family: var(--ff-display);
    font-size: 16px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase;
    padding: 14px 32px;
    border-radius: var(--radius);
    text-decoration: none;
    transition: background var(--transition), transform var(--transition);
    border: 2px solid var(--ore);
  }
  .btn-primary:hover { background: var(--spark); border-color: var(--spark); transform: translateY(-2px); }

  .btn-outline {
    display: inline-flex; align-items: center; gap: 8px;
    background: transparent;
    color: var(--white);
    font-family: var(--ff-display);
    font-size: 16px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase;
    padding: 14px 32px;
    border-radius: var(--radius);
    text-decoration: none;
    border: 2px solid rgba(255,255,255,0.38);
    transition: border-color var(--transition), color var(--transition);
  }
  .btn-outline:hover { border-color: var(--spark); color: var(--spark); }

  .hero-stats {
    position: relative; z-index: 2;
    display: flex; gap: 48px;
    margin-top: 56px;
    padding-top: 40px;
    border-top: 1px solid rgba(255,255,255,0.1);
  }
  .hero-stat-num {
    font-family: var(--ff-display);
    font-size: 42px; font-weight: 800;
    color: var(--spark);
    line-height: 1;
  }
  .hero-stat-label {
    font-size: 12px; letter-spacing: 0.12em; text-transform: uppercase;
    color: rgba(255,255,255,0.55);
    margin-top: 4px;
  }

  /* ── TRUCK SHOWCASE ──────────────────────────────────────────────────── */
  .truck-showcase {
    background: var(--navy);
    padding: 80px 5vw 0;
    position: relative;
  }

  .showcase-label {
    font-family: var(--ff-mono);
    font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase;
    color: var(--ore);
    margin-bottom: 40px;
    text-align: center;
  }

  .truck-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3px;
    max-width: 1200px;
    margin: 0 auto;
  }

  .truck-card {
    position: relative;
    overflow: hidden;
    background: var(--steel);
    aspect-ratio: 16/9;
  }

  .truck-card-img {
    width: 100%; height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.6s ease;
    filter: saturate(0.85) contrast(1.1);
  }
  .truck-card:hover .truck-card-img { transform: scale(1.04); }

  /* SVG-based truck illustration for 20ft unit */
  .truck-visual {
    width: 100%; height: 100%;
    position: relative;
    background: linear-gradient(135deg, #1a3a5c 0%, #0d2035 60%, #0a1826 100%);
    display: flex; align-items: flex-end; justify-content: center;
    overflow: hidden;
    padding-bottom: 24px;
  }

  /* Ground shadow */
  .truck-visual::before {
    content: '';
    position: absolute; bottom: 0; left: 0; right: 0;
    height: 40%;
    background: linear-gradient(0deg, rgba(0,0,0,0.5) 0%, transparent 100%);
  }

  .truck-label-overlay {
    position: absolute; bottom: 0; left: 0; right: 0;
    background: linear-gradient(0deg, rgba(13,31,60,0.95) 0%, transparent 100%);
    padding: 24px 28px 20px;
  }
  .truck-label-overlay h3 {
    font-family: var(--ff-display);
    font-size: 22px; font-weight: 800; text-transform: uppercase;
    color: var(--white);
  }
  .truck-label-overlay p {
    font-size: 13px; color: rgba(255,255,255,0.65);
    margin-top: 2px;
  }
  .truck-badge {
    position: absolute; top: 16px; right: 16px;
    background: var(--ore);
    color: var(--white);
    font-family: var(--ff-mono);
    font-size: 11px; letter-spacing: 0.1em;
    padding: 4px 12px;
    border-radius: 2px;
    text-transform: uppercase;
  }

  /* ── SECTION COMMON ─────────────────────────────────────────────────── */
  .section {
    padding: 100px 5vw;
  }

  .section-header {
    margin-bottom: 64px;
  }
  .section-eyebrow {
    font-family: var(--ff-mono);
    font-size: 11px; letter-spacing: 0.2em; text-transform: uppercase;
    color: var(--ore);
    margin-bottom: 12px;
    display: flex; align-items: center; gap: 10px;
  }
  .section-eyebrow::before {
    content: '';
    display: block; width: 24px; height: 2px; background: var(--ore);
  }
  .section-title {
    font-family: var(--ff-display);
    font-size: clamp(32px, 4.5vw, 56px);
    font-weight: 800; text-transform: uppercase;
    color: var(--navy);
    line-height: 1.0;
  }
  .section-title .ore { color: var(--ore); }
  .section-desc {
    font-size: 17px; color: var(--muted); line-height: 1.7;
    max-width: 560px;
    margin-top: 16px;
  }

  /* ── PRODUCTS / BESS ────────────────────────────────────────────────── */
  #products { background: var(--fog); }

  .products-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(340px, 1fr));
    gap: 24px;
  }

  .product-card {
    background: var(--white);
    border-radius: 6px;
    overflow: hidden;
    box-shadow: 0 2px 16px rgba(13,31,60,0.08);
    transition: box-shadow var(--transition), transform var(--transition);
    border-top: 4px solid var(--ore);
  }
  .product-card:hover {
    box-shadow: var(--shadow);
    transform: translateY(-4px);
  }

  /* BESS Container Visual */
  .bess-visual {
    height: 220px;
    position: relative;
    overflow: hidden;
  }

  .bess-20ft { background: linear-gradient(135deg, #0d2035 0%, #1a3a5c 50%, #0d2035 100%); }
  .bess-40ft { background: linear-gradient(135deg, #1a2c0d 0%, #243d12 50%, #1a2c0d 100%); }
  .bess-mobile { background: linear-gradient(135deg, #1a1a35 0%, #2a2a5c 50%, #1a1a35 100%); }

  .bess-svg-wrap {
    position: absolute; inset: 0;
    display: flex; align-items: center; justify-content: center;
  }

  .product-body {
    padding: 28px 28px 32px;
  }
  .product-tag {
    display: inline-block;
    font-family: var(--ff-mono);
    font-size: 10px; letter-spacing: 0.15em; text-transform: uppercase;
    color: var(--ore);
    border: 1px solid var(--ore);
    padding: 3px 10px; border-radius: 2px;
    margin-bottom: 12px;
  }
  .product-card h3 {
    font-family: var(--ff-display);
    font-size: 24px; font-weight: 800; text-transform: uppercase;
    color: var(--navy);
    margin-bottom: 10px;
  }
  .product-card p {
    font-size: 14px; color: var(--muted); line-height: 1.65;
    margin-bottom: 20px;
  }

  .spec-list {
    list-style: none;
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 8px 16px;
  }
  .spec-list li {
    font-size: 12px; color: var(--ink);
    display: flex; align-items: flex-start; gap: 6px;
  }
  .spec-list li::before {
    content: '▸';
    color: var(--ore);
    flex-shrink: 0;
    margin-top: 1px;
  }

  /* ── SECTORS ────────────────────────────────────────────────────────── */
  #sectors { background: var(--navy); }
  #sectors .section-title { color: var(--white); }
  #sectors .section-desc { color: rgba(255,255,255,0.58); }

  .sectors-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2px;
    margin-top: 64px;
  }

  .sector-panel {
    position: relative;
    height: 380px;
    overflow: hidden;
    cursor: default;
  }

  .sector-bg {
    position: absolute; inset: 0;
    background-size: cover; background-position: center;
    transition: transform 0.6s ease;
    filter: brightness(0.45) saturate(0.7);
  }
  .sector-panel:hover .sector-bg { transform: scale(1.07); filter: brightness(0.55) saturate(0.9); }

  .sector-content {
    position: absolute; inset: 0;
    display: flex; flex-direction: column; justify-content: flex-end;
    padding: 28px 24px;
    background: linear-gradient(0deg, rgba(13,31,60,0.92) 0%, transparent 60%);
  }

  .sector-icon {
    width: 44px; height: 44px;
    background: var(--ore);
    border-radius: 4px;
    display: flex; align-items: center; justify-content: center;
    margin-bottom: 12px;
    font-size: 22px;
  }

  .sector-content h3 {
    font-family: var(--ff-display);
    font-size: 22px; font-weight: 800; text-transform: uppercase;
    color: var(--white);
    margin-bottom: 6px;
  }
  .sector-content p {
    font-size: 12px; color: rgba(255,255,255,0.65); line-height: 1.55;
  }

  /* sector backgrounds using CSS gradients + patterns  */
  .sector-mining .sector-bg {
    background:
      url('https://images.unsplash.com/photo-1578662996442-48f60103fc96?w=800&q=80') center/cover,
      linear-gradient(135deg, #2a1a0a 0%, #3d2611 100%);
  }
  .sector-municipal .sector-bg {
    background:
      url('https://images.unsplash.com/photo-1486325212027-8081e485255e?w=800&q=80') center/cover,
      linear-gradient(135deg, #0a1a2a 0%, #112233 100%);
  }
  .sector-transnet .sector-bg {
    background:
      url('https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=800&q=80') center/cover,
      linear-gradient(135deg, #1a1a0a 0%, #252511 100%);
  }
  .sector-sandf .sector-bg {
    background:
      url('https://images.unsplash.com/photo-1504307651254-35680f356dfd?w=800&q=80') center/cover,
      linear-gradient(135deg, #0a1a0a 0%, #111f11 100%);
  }

  /* ── WHY ORECONNECT ─────────────────────────────────────────────────── */
  #why { background: var(--white); }

  .why-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
  }

  .why-features {
    display: flex; flex-direction: column; gap: 32px;
    margin-top: 40px;
  }

  .feature-item {
    display: flex; gap: 20px; align-items: flex-start;
  }
  .feature-num {
    font-family: var(--ff-display);
    font-size: 48px; font-weight: 900;
    color: var(--fog);
    line-height: 1;
    flex-shrink: 0;
    width: 52px;
    text-align: right;
    margin-top: -8px;
  }
  .feature-text h4 {
    font-family: var(--ff-display);
    font-size: 20px; font-weight: 700; text-transform: uppercase;
    color: var(--navy); margin-bottom: 4px;
  }
  .feature-text p { font-size: 14px; color: var(--muted); line-height: 1.6; }

  .why-visual {
    position: relative;
  }

  /* BESS + Truck composite illustration */
  .why-img-wrap {
    position: relative;
    border-radius: 6px;
    overflow: hidden;
    aspect-ratio: 4/3;
    background: var(--navy);
  }

  .why-main-img {
    width: 100%; height: 100%;
    object-fit: cover;
    opacity: 0.85;
  }

  .why-badge {
    position: absolute; top: 20px; left: 20px;
    background: var(--ore);
    color: var(--white);
    font-family: var(--ff-display);
    font-size: 14px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase;
    padding: 8px 18px;
    border-radius: var(--radius);
  }

  .why-certifications {
    display: flex; gap: 12px; flex-wrap: wrap;
    margin-top: 24px;
  }
  .cert-chip {
    font-family: var(--ff-mono);
    font-size: 11px; letter-spacing: 0.08em;
    color: var(--steel);
    border: 1px solid rgba(26,58,92,0.25);
    padding: 6px 14px; border-radius: 20px;
    background: var(--fog);
  }

  /* ── FLEET GALLERY ───────────────────────────────────────────────────── */
  #fleet { background: var(--fog); }

  .fleet-scroll {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    margin-top: 48px;
  }

  .fleet-item {
    position: relative;
    border-radius: 4px;
    overflow: hidden;
    aspect-ratio: 4/3;
    background: var(--navy);
  }

  .fleet-item-img {
    width: 100%; height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease, filter 0.5s ease;
    filter: saturate(0.8);
  }
  .fleet-item:hover .fleet-item-img {
    transform: scale(1.06);
    filter: saturate(1.1);
  }

  .fleet-item-label {
    position: absolute; bottom: 0; left: 0; right: 0;
    background: linear-gradient(0deg, rgba(13,31,60,0.9) 0%, transparent 100%);
    padding: 20px 16px 14px;
    font-family: var(--ff-display);
    font-size: 14px; font-weight: 700; text-transform: uppercase;
    color: var(--white); letter-spacing: 0.06em;
  }

  /* ── CONTACT ─────────────────────────────────────────────────────────── */
  #contact {
    background: var(--navy);
    position: relative; overflow: hidden;
  }

  #contact::before {
    content: '';
    position: absolute; inset: 0;
    background: repeating-linear-gradient(
      110deg, transparent 0px, transparent 48px,
      rgba(200,118,10,0.04) 48px, rgba(200,118,10,0.04) 50px
    );
    pointer-events: none;
  }

  .contact-grid {
    position: relative; z-index: 2;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: start;
  }

  #contact .section-title { color: var(--white); }
  #contact .section-desc { color: rgba(255,255,255,0.58); }

  .contact-info {
    margin-top: 40px;
    display: flex; flex-direction: column; gap: 28px;
  }

  .contact-item {
    display: flex; gap: 16px; align-items: flex-start;
  }
  .contact-icon {
    width: 44px; height: 44px; flex-shrink: 0;
    background: rgba(200,118,10,0.15);
    border: 1px solid rgba(200,118,10,0.35);
    border-radius: 4px;
    display: flex; align-items: center; justify-content: center;
    font-size: 20px;
  }
  .contact-item-label {
    font-family: var(--ff-mono);
    font-size: 10px; letter-spacing: 0.15em; text-transform: uppercase;
    color: var(--ore); margin-bottom: 4px;
  }
  .contact-item-value {
    font-size: 16px; font-weight: 600;
    color: var(--white);
  }
  .contact-item-value a {
    color: var(--white); text-decoration: none;
  }
  .contact-item-value a:hover { color: var(--spark); }
  .contact-item-sub {
    font-size: 13px; color: rgba(255,255,255,0.48);
    margin-top: 2px;
  }

  /* Contact form */
  .contact-form {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 6px;
    padding: 40px;
  }

  .contact-form h3 {
    font-family: var(--ff-display);
    font-size: 24px; font-weight: 700; text-transform: uppercase;
    color: var(--white); margin-bottom: 28px;
    letter-spacing: 0.04em;
  }

  .form-row {
    display: grid; grid-template-columns: 1fr 1fr; gap: 16px;
    margin-bottom: 16px;
  }

  .form-group {
    display: flex; flex-direction: column; gap: 6px;
    margin-bottom: 16px;
  }

  .form-group label {
    font-family: var(--ff-mono);
    font-size: 10px; letter-spacing: 0.15em; text-transform: uppercase;
    color: rgba(255,255,255,0.5);
  }

  .form-group input,
  .form-group select,
  .form-group textarea {
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.14);
    border-radius: var(--radius);
    padding: 12px 16px;
    font-family: var(--ff-body);
